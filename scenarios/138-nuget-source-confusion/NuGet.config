<?xml version="1.0" encoding="utf-8"?>
<!--
  scenarios/138-nuget-source-confusion
  CICD-SEC-3 (Dependency Chain Abuse) — NuGet / NuGet.config

  Pattern: two package sources are configured with NO <packageSourceMapping>.
  Without mapping, NuGet restore resolves each package id from whichever source
  offers the highest version, so an attacker who publishes a same-named package
  to the public gallery shadows the private one (NuGet dependency confusion).
  packageSourceMapping pins each id/prefix to one source and closes the gap.

  SAFETY: static fixture nested under scenarios/. `dotnet restore` is never
  invoked on this tree; pipeline-check parses NuGet.config statically. See README.md.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- DANGER — two sources, no <packageSourceMapping>: ids resolve from
         whichever source has the higher version (confusion surface). -->
    <add key="internal" value="https://nuget.internal.example.com/v3/index.json" />
  </packageSources>
</configuration>
