<?xml version="1.0" encoding="utf-8"?>
<!--
  scenarios/137-nuget-http-source
  CICD-SEC-3 (Dependency Chain Abuse) — NuGet / NuGet.config

  Pattern: a package source is declared over plain HTTP, and a private feed is
  added WITHOUT a <clear/> first — so the public nuget.org gallery is still
  active alongside it. With no <packageSourceMapping>, restore pulls each package
  from whichever source offers it, so a public-gallery package can shadow a
  private one (NuGet dependency confusion), and the HTTP feed has no TLS.

  SAFETY: static fixture nested under scenarios/. `dotnet restore` is never
  invoked on this tree; pipeline-check parses NuGet.config statically. See README.md.
-->
<configuration>
  <packageSources>
    <!-- no <clear/> — the implicit public nuget.org source stays active -->
    <!-- DANGER — private feed over plain HTTP, no TLS. -->
    <add key="internal" value="http://nuget.internal.example.com/v3/index.json" />
  </packageSources>
</configuration>
